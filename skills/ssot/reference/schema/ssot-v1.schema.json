{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ssot-v1",
  "title": "SSOT 대상(노드) frontmatter 규격 v1",
  "description": "모든 SSOT 대상 마크다운 파일의 YAML frontmatter가 따르는 규격. verify 스크립트가 이 규격을 의존성 없이 코드로 구현한다.",
  "type": "object",
  "required": ["id", "kind", "title", "confidence"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "description": "전역 유일 식별자. 형식: <kind소문자>.<kebab-slug> (예: domain.rag-manager, invariant.permission-ssot)",
      "pattern": "^(platform|persona|domain|concept|capability|component|integration|invariant|decision|rule|screen|endpoint|flow)\\.[a-z0-9][a-z0-9-]*$"
    },
    "kind": {
      "type": "string",
      "enum": ["Platform", "Persona", "Domain", "Concept", "Capability", "SystemComponent", "Integration", "Invariant", "Decision", "EngineeringRule", "Screen", "Endpoint", "Flow"]
    },
    "authority": {
      "type": "string",
      "enum": ["authored", "mirrored"],
      "description": "authored=원본이 SSOT(자기완결). mirrored=원본이 외부 레포 파일(source 단방향 동기화). 생략 시 authored."
    },
    "source": {
      "type": "string",
      "description": "[mirrored 전용] 원본 파일 경로(워크스페이스 루트 기준). 이 노드는 이 파일의 미러이며 SSOT에서 직접 편집하지 않는다. verify가 mirror-drift를 검사."
    },
    "title": { "type": "string", "minLength": 1 },

    "purpose":   { "type": "string", "description": "[축①] 이 대상이 존재하는 목적" },
    "servesPersona": { "type": "array", "items": { "type": "string" }, "description": "[축①] 대상 id 리스트 (→ Persona)" },
    "value":     { "type": "string", "description": "[축①] 제공 가치 명제" },

    "definition": { "type": "string", "description": "[축②] 정의/동의어" },
    "relatesTo": {
      "type": "array",
      "description": "[축②] 개념 간 관계. 객체 리스트.",
      "items": {
        "type": "object",
        "required": ["to", "type"],
        "properties": {
          "to":   { "type": "string", "description": "대상 id" },
          "type": { "type": "string", "description": "관계명 (contains/feeds/depends/...)" },
          "note": { "type": "string" }
        }
      }
    },
    "governedBy": { "type": "array", "items": { "type": "string" }, "description": "[축②] 대상 id 리스트 (→ Invariant)" },
    "governs":    { "type": "array", "items": { "type": "string" }, "description": "[축②] Invariant가 적용되는 대상 id 리스트" },

    "realizedBy":   { "type": "array", "items": { "type": "string" }, "description": "[축③] 대상 id 리스트 (→ SystemComponent)" },
    "implementedIn": { "type": "array", "items": { "type": "string" }, "description": "[축③] provenance — 이 진실이 현재 구현/반영된 코드·문서 위치. 근거가 아니라 drift 추적 앵커(내용은 본문에 자기완결적으로). verify가 실존을 검사." },
    "dependsOn":    { "type": "array", "items": { "type": "string" }, "description": "[축③] 대상 id 리스트 (→ SystemComponent)" },
    "consumesApi":  { "type": "array", "items": { "type": "string" }, "description": "[축③] API 엔트리 참조(경로 또는 외부 자산 링크)" },
    "providesApi":  { "type": "array", "items": { "type": "string" }, "description": "[축③] API 엔트리 참조" },
    "impacts":      { "type": "array", "items": { "type": "string" }, "description": "[축③] 개념적 파급 대상 id 리스트. 영향분석 핵심. 사람 검증 영역." },

    "owner":        { "type": "string", "description": "[축④] 검증 책임자. 'TBD' 허용." },
    "decidedBy":    { "type": "array", "items": { "type": "string" }, "description": "[축④] 대상 id 리스트 (→ Decision)" },
    "lifecycle":    { "type": "string", "enum": ["planned", "active", "deprecated"], "description": "[축④] 생명주기 상태. planned=기획됨(코드 없음), active=구현됨, deprecated=폐기예정. 생략 시 active로 간주." },
    "confidence":   { "type": "string", "enum": ["high", "inferred", "unverified"], "description": "[축④] high만 사람이 검증한 진실" },
    "lastVerified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "description": "[축④] 마지막 검증일 YYYY-MM-DD" },

    "tags":         { "type": "array", "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*:[a-z0-9][a-z0-9-]*$" }, "description": "[축④] 통제 어휘 태그. 형식 'namespace:value' (예: domain:auth, status:planned, team:fe, area:rbac). 허용 네임스페이스는 x-tags 참조. 자유 태그 금지." },
    "introducedIn": { "type": "string", "pattern": "^v\\d+\\.\\d+\\.\\d+$", "description": "[축④] 이 진실이 처음 도입된 제품 버전 (예: v2.5.4)." },
    "targetVersion":{ "type": "string", "pattern": "^v\\d+\\.\\d+\\.\\d+$", "description": "[축④] planned 노드가 구현 예정인 목표 버전 (예: v2.6.0)." }
  },

  "x-tags": {
    "_comment": "tags 의 허용 네임스페이스 통제 어휘. tags[] 의 각 항목은 'namespace:value' 형식이며 namespace 가 아래 목록에 있어야 한다. value 는 소문자 kebab. verify 가 비허용 네임스페이스/형식 위반을 경고(차단 아님).",
    "namespaces": {
      "domain":  "소속 도메인 분류 (예: domain:auth, domain:rbac, domain:llmops). Domain 노드 id 의 slug 와 정렬 권장.",
      "area":    "기능 영역/서브시스템 (예: area:rbac, area:billing, area:agent).",
      "status":  "작업/진행 상태 라벨 (예: status:planned, status:wip, status:stable). lifecycle 필드와 중복 가능하나 필터 편의용.",
      "team":    "책임 팀 (예: team:fe, team:be, team:platform).",
      "version": "버전 관련 라벨 (예: version:v2-5-4, version:next). 정밀 버전은 introducedIn/targetVersion 필드 사용 권장.",
      "type":    "보조 분류 태그 (예: type:public-api, type:internal).",
      "risk":    "리스크/주의 라벨 (예: risk:security, risk:breaking)."
    }
  },

  "x-required-facets-by-kind": {
    "_comment": "kind별로 '측면 완전성'을 위해 채워져야 하는 필드. 빈칸 일급 규약상 TBD/unverified/OPEN로 명시되면 채워진 것으로 본다. verify가 이 목록으로 측면 누락을 검사.",
    "Platform":        ["purpose", "servesPersona", "value", "owner", "confidence"],
    "Persona":         ["purpose", "definition", "owner", "confidence"],
    "Domain":          ["purpose", "definition", "servesPersona", "relatesTo", "realizedBy", "owner", "confidence"],
    "Concept":         ["definition", "relatesTo", "governedBy", "owner", "confidence"],
    "Capability":      ["purpose", "servesPersona", "realizedBy", "implementedIn", "owner", "confidence"],
    "SystemComponent": ["purpose", "realizedBy", "implementedIn", "owner", "confidence"],
    "Integration":     ["purpose", "integratesWith", "impacts", "owner", "confidence"],
    "Invariant":       ["definition", "governs", "implementedIn", "decidedBy", "owner", "confidence"],
    "Decision":        ["purpose", "definition", "owner", "confidence", "lastVerified"],
    "EngineeringRule": ["definition", "source", "authority", "owner", "confidence"],
    "Screen":          ["purpose", "servesPersona", "implementedIn", "owner", "confidence"],
    "Endpoint":        ["definition", "implementedIn", "owner", "confidence"],
    "Flow":            ["purpose", "servesPersona", "relatesTo", "owner", "confidence"]
  },

  "x-id-reference-fields": {
    "_comment": "값이 '대상 id'를 가리키는 필드들. verify가 연결 완전성(끊긴 엣지)을 검사할 때 사용. relatesTo는 객체의 .to가 id.",
    "idList": ["servesPersona", "governedBy", "realizedBy", "dependsOn", "impacts", "decidedBy", "governs"],
    "objectList": ["relatesTo"],
    "pathList": ["implementedIn"]
  },

  "x-edge-types": {
    "_comment": "relatesTo[].type 의 표준 어휘집(type→의미). verify가 비표준 type을 '정보 레벨'로 리포트(차단 아님, 권장). 새 관계가 필요하면 더 구체적인 표준 type을 고르고, 정말 분류 불가할 때만 relates-to(fallback)를 쓴다.",
    "calls": "Screen/Component가 Endpoint를 호출(소비)한다. FE→API 호출 표면의 기본 엣지.",
    "backed-by": "노드(주로 Endpoint/Concept/Capability)가 특정 백엔드 모듈/Concept에 의해 구현·지원된다. provenance성 '구현 근거' 엣지.",
    "belongs-to": "노드가 상위 Concept/Domain에 소속·분류된다. 분류/그룹핑 관계의 표준.",
    "reads": "조회(read-only) 데이터 접근. Endpoint/Capability가 Concept의 상태를 읽는다.",
    "mutates": "쓰기(write) 데이터 변경. create/update/delete 류를 포괄하는 변경 관계의 표준.",
    "relates-to": "분류 불가한 일반 연관. 더 구체적인 엣지가 없을 때만 쓰는 fallback 관계.",
    "realizes": "Capability/Endpoint가 상위 의도(Capability/Concept/Domain 행위)를 실현·구현한다. 추상→구체 실현 관계.",
    "creates-instance-of": "런타임 인스턴스를 생성한다(instance lifecycle: create). 도메인 엔티티의 생성 행위.",
    "deletes-instance-of": "런타임 인스턴스를 삭제한다(instance lifecycle: delete).",
    "mutates-instance-of": "런타임 인스턴스를 수정한다(instance lifecycle: update).",
    "mirrors": "두 노드가 동일 데이터/구조를 거울처럼 반영(FE 타입 ↔ BE 엔티티, 동일 테이블 공유 등). 구조 동등성 관계.",
    "aggregates": "여러 단위 데이터를 상위 단위로 집계한다(통계/사용량 집계).",
    "preceded-by": "Flow/시퀀스에서 선행 단계. 순서 관계의 '이전' 방향.",
    "leads-to": "Flow/시퀀스/네비게이션에서 다음 단계로 이어진다. 순서 관계의 '다음' 방향(navigates-to/redirects-to 포함).",
    "configures": "설정/구성 값을 정의·주입한다(RAG 설정, public URL 등).",
    "governs": "정책·제약·권한·만료 등을 통제·강제한다(gates/enforces/locks/guards 포함).",
    "measures": "사용량/비용 등 지표를 측정·귀속한다(measures-usage-of, measures-cost-of).",
    "ranks": "지표 기준으로 순위를 매긴다(ranks-by-usage, ranks-cost-of).",
    "contains": "구성요소를 포함·소유한다(부분-전체, owns/partOf 역방향).",
    "scopes": "접근/가시성/적용 범위를 한정한다(scopes-access-to, scopedBy, scopedTo).",
    "assigns": "역할/멤버/모델 등을 대상에 배정·바인딩한다(binds/assignedTo 포함).",
    "feeds": "데이터/입력을 하류로 공급한다(파이프라인 데이터 흐름).",
    "depends-on": "런타임/빌드 의존. 동작을 위해 다른 노드가 필요하다.",
    "complements": "동급 노드가 상호 보완한다(complementedBy 포함).",
    "sibling-of": "동일 상위 아래 형제 관계의 동급 노드(variantOf/analogousTo 포함).",
    "exposes": "기능/도구/API 표면을 외부에 노출·제공한다(provides/providesTools 포함).",
    "integrates-with": "외부 시스템/Integration과 연동한다(authenticates/syncs 외부 연동 축).",
    "triggers": "이벤트/배치/캐시이벤트/스케줄을 유발한다(triggeredBy/scheduledBy/triggersCacheEvent 포함).",
    "lists": "컬렉션 조회. reads의 다중-항목 전문화(lists-* 계열 전부 흡수).",
    "evaluates": "평가/테스트/검증을 수행한다(tests/validates/analyzes 계열)."
  },

